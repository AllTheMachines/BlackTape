node_modules

# Output
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS
.DS_Store
Thumbs.db

# Env
.env
.env.*
!.env.example
!.env.test

# Wrangler local dev secrets (never commit real credentials)
.dev.vars

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Tauri (Rust build output)
src-tauri/target/
src-tauri/gen/

# Sidecar binaries (downloaded separately, not committed)
src-tauri/binaries/*.exe

# Pipeline data (large dumps + generated database)
data/
pipeline/data/

# Signing keys (never commit)
*.key
*.key.pub

# Temporary icon source
app-icon.png

# Large media files
*.mp4
*.mov
*.mkv
press-screenshots/

# app-recordings -- commit metadata and press shots, ignore large video files
app-recordings/*/takes/
app-recordings/*/final/*.mp4
app-recordings/*/final/*.webm

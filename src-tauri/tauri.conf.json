{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "BlackTape",
  "identifier": "com.blacktape.app",
  "version": "0.3.0",
  "build": {
    "beforeDevCommand": "npx cross-env VITE_TAURI=1 npm run dev",
    "beforeBuildCommand": "npx cross-env TAURI_ENV=1 VITE_TAURI=1 npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "BlackTape",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "externalBin": [
      "binaries/llama-server"
    ],
    "resources": {
      "binaries/*.dll": "."
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBOTI3MkZEQjZENThFMzYKUldRMmp0VzIvWEtTeXJUc05mMzNGTnlFcTFqMEpGZCtZQXRBSWp1Q0tzVFFJMk9hUG02MWdiTUsK",
      "endpoints": [
        "https://github.com/AllTheMachines/BlackTape/releases/latest/download/latest.json"
      ]
    }
  }
}

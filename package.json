{
	"name": "mercury",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:fresh": "node tools/kill-dev.mjs && vite dev",
		"kill": "node tools/kill-dev.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"build:desktop": "cross-env TAURI_ENV=1 VITE_TAURI=1 vite build",
		"tauri": "tauri",
		"tauri:dev": "cross-env VITE_TAURI=1 tauri dev",
		"tauri:build": "tauri build"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260214.0",
		"@sveltejs/adapter-cloudflare": "^7.2.7",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tauri-apps/cli": "^2.10.0",
		"@types/d3-force": "^3.0.10",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.2.3",
		"cross-env": "^10.1.0",
		"glob": "^13.0.6",
		"playwright": "^1.58.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@dicebear/core": "^9.3.2",
		"@dicebear/pixel-art": "^9.3.2",
		"@fabianlars/tauri-plugin-oauth": "^2.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"@tauri-apps/plugin-sql": "^2.3.2",
		"@tauri-apps/plugin-updater": "^2.10.0",
		"d3-force": "^3.0.0",
		"leaflet": "^1.9.4",
		"paneforge": "^1.0.2"
	}
}
